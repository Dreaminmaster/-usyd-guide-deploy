<script>
const DATA={"verified":"2026-07-21","categories":[{"id":"timeline","name":"时间线与报到","icon":"◷","desc":"从 offer、CoE 到抵澳、报到和开课"},{"id":"cet","name":"CET / DEC 语言班","icon":"文","desc":"课程日期、出勤、Canvas、考核和升读"},{"id":"enrol","name":"正式入学与选课","icon":"课","desc":"enrolment、units、课表和课程进度"},{"id":"systems","name":"学校系统","icon":"⌘","desc":"UniKey、Okta、邮箱、MyUni、Canvas、Wi‑Fi"},{"id":"card","name":"学生证与 Apple Wallet","icon":"卡","desc":"实体卡、数字卡、门禁、打印和 SydPay"},{"id":"visa","name":"签证与合规","icon":"签","desc":"工作时数、地址、OSHC、CoE 与国际学生义务"},{"id":"study","name":"学习与学术规范","icon":"学","desc":"学习方法、引用、AI、诚信和支持"},{"id":"assessment","name":"考试与成绩","icon":"考","desc":"考试证件、延期、特殊考虑、复核和申诉"},{"id":"library","name":"图书馆与设施","icon":"馆","desc":"图书馆、打印、软件、学习空间和实验室"},{"id":"housing","name":"租房与住宿","icon":"⌂","desc":"合同、bond、查房、维修和防诈骗"},{"id":"transport","name":"交通与出行","icon":"行","desc":"Opal、优惠资格、机场、骑行和夜间安全"},{"id":"health","name":"医疗与心理","icon":"医","desc":"OSHC 就诊、GP、药房、心理支持和紧急情况"},{"id":"money","name":"银行、手机与生活","icon":"$","desc":"开户、电话卡、预算、税号和日常生活"},{"id":"benefits","name":"免费资源与福利","icon":"★","desc":"FoodHub、USU、软件、活动、折扣和隐藏权益"},{"id":"work","name":"工作与职业发展","icon":"职","desc":"TFN、合法工作、简历、实习和毕业准备"},{"id":"emergency","name":"紧急与故障处理","icon":"!","desc":"账号、证件、租房、健康和校园紧急流程"}],"topics":[{"id":"timeline-1","category":"timeline","title":"收到 offer 后的正确顺序","summary":"核对课程、条件、学费、OSHC 和截止日期，再决定接受并获取 CoE。","priority":"high","tags":["offer","CoE"],"source":"new_students","stage":"before","verified":"2026-07-21","type":"guide","steps":["逐字核对 offer 与个人邮件","确认是否有语言、学历、付款或材料条件","按指示接受 offer 并付款","收到 CoE 后核对姓名、课程和日期"],"sourceKeys":["new_students"],"officialPath":"","prerequisites":[],"sections":[],"warnings":[],"troubleshooting":[]},{"id":"timeline-2","category":"timeline","title":"Offer 日期与官网日期不一致","summary":"优先使用个人 offer、CoE 和学校邮件；官网公开日期只是通用信息。","priority":"high","tags":["日期","冲突"],"source":"cet_dates","stage":"before","verified":"2026-07-21","type":"guide","steps":["逐字核对 offer 与个人邮件","确认是否有语言、学历、付款或材料条件","按指示接受 offer 并付款","收到 CoE 后核对姓名、课程和日期"],"sourceKeys":["cet_dates"],"officialPath":"","prerequisites":[],"sections":[],"warnings":[],"troubleshooting":[]},{"id":"timeline-3","category":"timeline","title":"CoE 有什么用","summary":"CoE 是学生签证和课程状态的重要文件；课程变化后需检查是否更新。","priority":"high","tags":["CoE","签证"],"source":"visa_usyd","stage":"before","verified":"2026-07-21","type":"guide","steps":["逐字核对 offer 与个人邮件","确认是否有语言、学历、付款或材料条件","按指示接受 offer 并付款","收到 CoE 后核对姓名、课程和日期"],"sourceKeys":["visa_usyd"],"officialPath":"","prerequisites":[],"sections":[],"warnings":[],"troubleshooting":[]},{"id":"timeline-4","category":"timeline","title":"什么时候能 enrol","summary":"满足条件并进入学校指定窗口后才能 enrol；Sydney App 未显示不等于录取失效。","priority":"high","tags":["enrol","Sydney App"],"source":"enrol","stage":"before","verified":"2026-07-21","type":"guide","steps":["逐字核对 offer 与个人邮件","确认是否有语言、学历、付款或材料条件","按指示接受 offer 并付款","收到 CoE 后核对姓名、课程和日期"],"sourceKeys":["enrol"],"officialPath":"","prerequisites":[],"sections":[],"warnings":[],"troubleshooting":[]},{"id":"timeline-5","category":"timeline","title":"语言班和正式学位是两个 enrolment 阶段","summary":"CET/DEC 与正式学位可能由不同系统、团队和时间窗口处理，不应假设一次 enrol 覆盖全部。","priority":"high","tags":["CET","学位"],"source":"cet","stage":"before","verified":"2026-07-21","type":"guide","steps":["逐字核对 offer 与个人邮件","确认是否有语言、学历、付款或材料条件","按指示接受 offer 并付款","收到 CoE 后核对姓名、课程和日期"],"sourceKeys":["cet"],"officialPath":"","prerequisites":[],"sections":[],"warnings":[],"troubleshooting":[]},{"id":"timeline-6","category":"timeline","title":"抵澳后第一周","summary":"更新在澳状态、地址和联系方式，完成系统、学生证、交通、银行与课程检查。","priority":"high","tags":["抵澳","第一周"],"source":"international","stage":"arrival","verified":"2026-07-21","type":"checklist","steps":["更新澳洲地址与联系方式","完成 onshore / USI 等要求","确认课表、Canvas 和教室","准备实体与数字学生证"],"sourceKeys":["international"],"officialPath":"","prerequisites":[],"sections":[],"warnings":[],"troubleshooting":[]},{"id":"timeline-7","category":"timeline","title":"开课前 72 小时检查","summary":"检查 Canvas、课表、教室、导师公告、出勤规则和第一周任务。","priority":"medium","tags":["开课","检查"],"source":"canvas","stage":"arrival","verified":"2026-07-21","type":"checklist","steps":["更新澳洲地址与联系方式","完成 onshore / USI 等要求","确认课表、Canvas 和教室","准备实体与数字学生证"],"sourceKeys":["canvas"],"officialPath":"","prerequisites":[],"sections":[],"warnings":[],"troubleshooting":[]},{"id":"timeline-8","category":"timeline","title":"保存 case number","summary":"向学校提交 enquiry 后保存编号、截图和附件，追踪时引用同一 case。","priority":"medium","tags":["enquiry","case"],"source":"student_centre","stage":"all","verified":"2026-07-21","type":"guide","steps":["逐字核对 offer 与个人邮件","确认是否有语言、学历、付款或材料条件","按指示接受 offer 并付款","收到 CoE 后核对姓名、课程和日期"],"sourceKeys":["student_centre"],"officialPath":"","prerequisites":[],"sections":[],"warnings":[],"troubleshooting":[]},{"id":"timeline-9","category":"timeline","title":"不要只看 Sydney App","summary":"关键状态应交叉查看 Sydney Student、学校邮箱、Canvas 和个人文件。","priority":"medium","tags":["App","状态"],"source":"myuni","stage":"all","verified":"2026-07-21","type":"guide","steps":["逐字核对 offer 与个人邮件","确认是否有语言、学历、付款或材料条件","按指示接受 offer 并付款","收到 CoE 后核对姓名、课程和日期"],"sourceKeys":["myuni"],"officialPath":"","prerequisites":[],"sections":[],"warnings":[],"troubleshooting":[]},{"id":"timeline-10","category":"timeline","title":"时区与截止日期","summary":"学校日期通常按悉尼当地时间；人在海外时不要按中国或美国本地时间猜。","priority":"medium","tags":["时区","截止"],"source":"dates","stage":"all","verified":"2026-07-21","type":"guide","steps":["逐字核对 offer 与个人邮件","确认是否有语言、学历、付款或材料条件","按指示接受 offer 并付款","收到 CoE 后核对姓名、课程和日期"],"sourceKeys":["dates"],"officialPath":"","prerequisites":[],"sections":[],"warnings":[],"troubleshooting":[]},{"id":"timeline-11","category":"timeline","title":"个人文件夹怎么建","summary":"按 Offer、CoE、Visa、OSHC、Enrolment、Housing、Receipts 分类，并保留离线副本。","priority":"low","tags":["文件","备份"],"source":"international","stage":"before","verified":"2026-07-21","type":"guide","steps":["逐字核对 offer 与个人邮件","确认是否有语言、学历、付款或材料条件","按指示接受 offer 并付款","收到 CoE 后核对姓名、课程和日期"],"sourceKeys":["international"],"officialPath":"","prerequisites":[],"sec