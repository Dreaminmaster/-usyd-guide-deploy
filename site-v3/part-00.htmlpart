me":"USU clubs and societies","url":"https://usu.edu.au/clubs/","type":"USU","checked":"2026-07-21","firstParty":true,"authority":"University of Sydney Union"},"foodhub":{"name":"USU FoodHub","url":"https://usu.edu.au/foodhub/","type":"USU","checked":"2026-07-21","firstParty":true,"authority":"University of Sydney Union"},"financial_support":{"name":"Financial support","url":"https://www.sydney.edu.au/students/financial-support.html","type":"USYD","checked":"2026-07-21","firstParty":true,"authority":"University of Sydney"},"careers":{"name":"Careers Centre","url":"https://www.sydney.edu.au/students/careers.html","type":"USYD","checked":"2026-07-21","firstParty":true,"authority":"University of Sydney"},"student_centre":{"name":"Student Centre","url":"https://www.sydney.edu.au/students/student-centre.html","type":"USYD","checked":"2026-07-21","firstParty":true,"authority":"University of Sydney"},"dates":{"name":"Study dates","url":"https://www.sydney.edu.au/students/key-dates.html","type":"USYD","checked":"2026-07-21","firstParty":true,"authority":"University of Sydney"},"moneysmart":{"name":"Moneysmart","url":"https://moneysmart.gov.au/","type":"Australian Government","checked":"2026-07-21","firstParty":true,"authority":"ASIC"},"scamwatch":{"name":"Scamwatch","url":"https://www.scamwatch.gov.au/","type":"Australian Government","checked":"2026-07-21","firstParty":true,"authority":"National Anti-Scam Centre"},"acma":{"name":"ACMA mobile phone information","url":"https://www.acma.gov.au/phone-and-internet","type":"Australian Government","checked":"2026-07-21","firstParty":true,"authority":"ACMA"},"accc":{"name":"Consumer guarantees","url":"https://www.accc.gov.au/consumers/buying-products-and-services/consumer-rights-and-guarantees","type":"Australian Government","checked":"2026-07-21","firstParty":true,"authority":"ACCC"},"ato_tfn":{"name":"Apply for a TFN","url":"https://www.ato.gov.au/individuals-and-families/tax-file-number/apply-for-a-tfn","type":"Australian Govern