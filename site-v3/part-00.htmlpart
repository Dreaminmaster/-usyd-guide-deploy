e","verified":"2026-07-21","type":"guide","steps":["以 offer 和 CET 邮件确认课程日期","每天检查 Canvas 与课程公告","按要求参加 orientation 和所有课程活动","遇到健康或签证问题立即书面联系 CET"],"sourceKeys":["cet_current"],"officialPath":"","prerequisites":[],"sections":[],"warnings":[],"troubleshooting":[]},{"id":"cet-5","category":"cet","title":"生病缺课怎么办","summary":"尽快通知教师或 CET，保存医疗证明并按课程规定提交，不要等到期末解释。","priority":"high","tags":["生病","缺课"],"source":"cet_current","stage":"language","verified":"2026-07-21","type":"guide","steps":["以 offer 和 CET 邮件确认课程日期","每天检查 Canvas 与课程公告","按要求参加 orientation 和所有课程活动","遇到健康或签证问题立即书面联系 CET"],"sourceKeys":["cet_current"],"officialPath":"","prerequisites":[],"sections":[],"warnings":[],"troubleshooting":[]},{"id":"cet-6","category":"cet","title":"Canvas 看不到课程","summary":"先确认课程开始日期和账号，再检查 Dashboard、Courses、邮箱和 CET 通知。","priority":"high","tags":["Canvas","课程"],"source":"canvas","stage":"language","verified":"2026-07-21","type":"guide","steps":["以 offer 和 CET 邮件确认课程日期","每天检查 Canvas 与课程公告","按要求参加 orientation 和所有课程活动","遇到健康或签证问题立即书面联系 CET"],"sourceKeys":["canvas"],"officialPath":"","prerequisites":[],"sections":[],"warnings":[],"troubleshooting":[]},{"id":"cet-7","category":"cet","title":"如何理解语言班 assessment","summary":"不要只看总分；逐项阅读 rubric、任务说明、引用要求和提交格式。","priority":"high","tags":["assessment","rubric"],"source":"cet_current","stage":"language","verified":"2026-07-21","type":"guide","steps":["以 offer 和 CET 邮件确认课程日期","每天检查 Canvas 与课程公告","按要求参加 orientation 和所有课程活动","遇到健康或签证问题立即书面联系 CET"],"sourceKeys":["cet_current"],"officialPath":"","prerequisites":[],"sections":[],"warnings":[],"troubleshooting":[]},{"id":"cet-8","category":"cet","title":"DEC 通过后如何衔接学位","summary":"达到课程要求后仍需等待正式学位 enrolment、选课和课表流程完成。","priority":"high","tags":["升读","衔接"],"source":"cet_current","stage":"language","verified":"2026-07-21","type":"guide","steps":["以 offer 和 CET 邮件确认课程日期","每天检查 Canvas 与课程公告","按要求参加 orientation 和所有课程活动","遇到健康或签证问题立即书面联系 CET"],"sourceKeys":["cet_current"],"officialPath":"","prerequisites":[],"sections":[],"warnings":[],"troubleshooting":[]},{"id":"cet-9","category":"cet","title":"语言班期间每天检查什么","summary":"学校邮箱、Canvas Announcements、Calendar、Assignments、Grades 和教师消息。","priority":"medium","tags":["每日","检查"],"source":"canvas","stage":"language","verified":"2026-07-21","type":"checklist","steps":["以 offer 和 CET 邮件确认课程日期","每天检查 Canvas 与课程公告","按要求参加 orientation 和所有课程活动","遇到健康或签证问题立即书面联系 CET"],"sourceKeys":["canvas"],"officialPath":"","prerequisites":[],"sections":[],"warnings":[],"troubleshooting":[]},{"id":"cet-10","category":"cet","title":"引用和抄袭风险","summary":"翻译、改写或使用 AI 不会自动消除来源责任，必须按任务要求引用。","priority":"high","tags":["引用","AI"],"source":"integrity","stage":"language","verified":"2026-07-21","type":"guide","steps":["以 offer 和 CET 邮件确认课程日期","每天检查 Canvas 与课程公告","按要求参加 orientation 和所有课程活动","遇到健康或签证问题立即书面联系 CET"],"sourceKeys":["integrity"],"officialPath":"","prerequisites":[],"sections":[],"warnings":[],"troubleshooting":[]},{"id":"cet-11","category":"cet","title":"小组任务如何留证据","summary":"保存分工、版本历史、会议记录和个人贡献，避免出现贡献争议。","priority":"medium","tags":["小组","证据"],"source":"integrity","stage":"language","verified":"2026-07-21","type":"guide","steps":["以 offer 和 CET 邮件确认课程日期","每天检查 Canvas 与课程公告","按要求参加 orientation 和所有课程活动","遇到健康或签证问题立即书面联系 CET"],"sourceKeys":["integrity"],"officialPath":"","prerequisites":[],"sections":[],"warnings":[],"troubleshooting":[]},{"id":"cet-12","category":"cet","title":"不要根据他人班级猜自己的要求","summary":"不同 intake、教师、课程长度和任务可能不同，以自己 Canvas 与课程手册为准。","priority":"high","tags":["个体","要求"],"source":"cet_current","stage":"language","verified":"2026-07-21","type":"guide","steps":["以 offer 和 CET 邮件确认课程日期","每天检查 Canvas 与课程公告","按要求参加 orientation 和所有课程活动","遇到健康或签证问题立即书面联系 CET"],"sourceKeys":["cet_current"],"officialPath":"","prerequisites":[],"sections":[],"warnings":[],"troubleshooting":[]},{"id":"enrol-1","category":"enrol","title":"Sydney Student 正式 enrolment","summary":"在 My Studies 中按步骤确认个人信息、课程和声明；完成后再检查状态。","priority":"high","tags":["Sydney Student","enrolment"],"source":"enrol","stage":"degree","verified":"2026-07-21","type":"guide","steps":["进入 Sydney Student → My Studies","完成 enrolment 步骤和声明","按 handbook 与课程规则选择 units","在 My Studies → Units of study 查看结果"],"sourceKeys":["enrol","select_units","units"],"officialPath":"Sydney Student → My Studies → Enrolment","prerequisites":["已接受 unconditional offer 或满足全部条件。","收到学校通知，确认 enrolment 已开放。","准备护照、地址、USI、紧急联系人和付款/贷款相关信息。"],"sections":[{"title":"开始 enrolment","items":["登录 Sydney Student，进入 My Studies。","选择 Enrolment，并核对课程名称、开始日期和个人身份信息。","按页面顺序完成地址、联系方式、USI、签证、统计信息和声明。","提交后记录状态，并保存确认页或截图。"]},{"title":"完成后检查","items":["回到 My Studies，确认课程状态不再显示未完成。","进入 Units of study 检查是否可选课。","查看学校邮箱是否有 enrolment confirmation。","如果 Sydney App 仍显示旧状态，以 Sydney Student 和邮件为准，并允许系统同步。"]},{"title":"接着完成的事项","items":["选择 units of study。","提交 timetable preferences 或查看个人课表。","检查 Canvas 是否出现课程；课程开放时间可能晚于 enrolment。","准备学生证照片与数字学生证。"]}],"warnings":["语言班 enrolment 与正式学位 enrolment 可能是不同流程。","不要在不理解课程规则时随意改变 study load；国际学生需同时考虑签证和 CoE。","个人 offer、邮件和登录后的系统提示优先于通用截图。"],"troubleshooting":["没有 My Studies 或 Enrolment：确认是否登录正确 UniKey、是否到开放日期、offer 条件是否满足。","页面保存失败：使用受支持浏览器、关闭翻译插件、清缓存或开无痕窗口。","课程信息不对：不要提交，截屏后联系 Student Centre 或 admissions。","提交后仍显示未 enrol：先重新登录并检查邮件；若持续，提交 online enquiry 并保存 case number。"]},{"id":"enrol-2","category":"enrol","title":"My Studies 在哪里","summary":"登录 Sydney Student 后从主菜单进入 My Studies；若没有，通常需要检查开放时间或账号状态。","priority":"high","tags":["My Studies","菜单"],"source":"sydney_student","stage":"degree","verified":"2026-07-21","type":"guide","steps":["进入 Sydney Student → My Studies","完成 enrolment 步骤和声明","按 handbook 与课程规则选择 units","在 My Studies → Units of study 查看结果"],"sourceKeys":["sydney_student"],"officialPath":"","prerequisites":[],"sections":[],"warnings":[],"troubleshooting":[]},{"id":"enrol-3","category":"enrol","title":"如何选择 units of study","summary":"先读 handbook 和 course resolutions，再按年度、semester、核心、专业与选修要求选择。","priority":"high","tags":["units","选课"],"source":"select_units","stage":"degree","verified":"2026-07-21","type":"guide","steps":["进入 Sydney Student → My Studies","完成 enrolment 步骤和声明","按 handbook 与课程规则选择 units","在 My Studies → Units of study 查看结果"],"sourceKeys":["select_units","handbook","units"],"officialPath":"Sydney Student → My Studies → Units of study → Change units of study","prerequisites":["已经正式 enrol。","打开对应入学年份的 handbook 和 course resolutions。","确认专业、specialisation、学分和预计完成时间。"],"sections":[{"title":"先建立课程结构","items":["列出全部 core units、专业/方向要求、capstone 或 thesis、选修和总学分。","按 prerequisite 和 assumed knowledge 排出先后顺序。","把课程放入具体 semester，检查是否只在特定学期开设。","不要只复制他人的选课表；不同入学年份和学分减免会改变结构。"]},{"title":"在 Sydney Student 选课","items":["进入 My Studies → Units of study。","选择 Change units of study。","按系统步骤选择当前 academic year 和 teaching period。","使用 unit code 或列表添加科目；保存后继续到确认页面。","完成 declaration 并提交。"]},{"title":"用 Tracking totals 检查","items":["查看页面顶部 Tracking totals。","每个 collection 都应达到或不超过所需学分。","如果显示 over-collection、under-collection 或无法归类，返回调整。","确认保存后重新打开 Units of study，确保变更已生效。"]},{"title":"选完后继续","items":["等待或提交 timetable preferences。","检查 Canvas 出现时间，不要因暂未出现而重复改选。","保存当前课程结构和 unit code 清单。","在 census date 前再次检查学分和退选风险。"]}],"warnings":["选到系统允许的科目，不等于一定符合你的 degree resolutions。","国际学生改变 study load、退课或延期可能影响 CoE 和签证。","不要只追求“好过”；需要同时考虑 prerequisite、毕业能力和职业目标。"],"troubleshooting":["搜不到 unit：检查是否在该学期开设、是否输入正确 code、是否属于正确 collection。","系统提示 prerequisite：核对是否已完成、获得 credit，或是否需要申请 waiver。","Tracking totals 不平：截图所有 collection，整理拟选 units 后联系 faculty adviser。","时间冲突：先完成选课，再通过 Sydney Timetable 处理 preference 或 clash 流程。"]},{"id":"enrol-4","category":"enrol","title":"Tracking totals 是什么","summary":"用于检查各课程 collection 已选学分；出现不足、超选或错误归类时要处理。","priority":"high","tags":["Tracking totals","学分"],"source":"select_units","stage":"degree","verified":"2026-07-21","type":"guide","steps":["进入 Sydney Student → My Studies","完成 enrolment 步骤和声明","按 handbook 与课程规则选择 units","在 My Studies → Units of study 查看结果"],"sourceKeys":["select_units"],"officialPath":"","prerequisites":[],"sections":[],"warnings":[],"troubleshooting":[]},{"id":"enrol-5","category":"enrol","title":"课程 Handbook 怎么用","summary":"选择正确入学年份，核对 course resolutions、unit table、prerequisites 和学习计划。","priority":"high","tags":["Handbook","规则"],"source":"handbook","stage":"degree","verified":"2026-07-21","type":"guide","steps":["进入 Sydney Student → My Studies","完成 enrolment 步骤和声明","按 handbook 与课程规则选择 units","在 My Studies → Units of study 查看结果"],"sourceKeys":["handbook"],"officialPath":"","prerequisites":[],"sections":[],"warnings":[],"troubleshooting":[]},{"id":"enrol-6","category":"enrol","title":"核心课、专业课和选修课","summary":"这些 collection 的学分不可随意互换，需按 course resolutions 完成。","priority":"high","tags":["core","elective"],"source":"handbook","stage":"degree","verified":"2026-07-21","type":"guide","steps":["进入 Sydney Student → My Studies","完成 enrolment 步骤和声明","按 handbook 与课程规则选择 units","在 My Studies → Units of study 查看结果"],"sourceKeys":["handbook"],"officialPath":"","prerequisites":[],"sections":[],"warnings":[],"troubleshooting":[]},{"id":"enrol-7","category":"enrol","title":"Prerequisite 与 assumed knowledge","summary":"prerequisite 是正式先修要求；assumed knowledge 是默认具备但不一定由系统硬拦截。","priority":"medium","tags":["先修","知识"],"source":"units","stage":"degree","verified":"2026-07-21","type":"guide","steps":["进入 Sydney Student → My Studies","完成 enrolment 步骤和声明","按 handbook 与课程规则选择 units","在 My Studies → Units of study 查看结果"],"sourceKeys":["units"],"officialPath":"","prerequisites":[],"sections":[],"warnings":[],"troubleshooting":[]},{"id":"enrol-8","category":"enrol","title":"选课系统允许不代表课程结构正确","summary":"系统可能不会替你判断全部 degree rules，必须自己用 handbook 和 adviser 复核。","priority":"high","tags":["规则","复核"],"source":"select_units","stage":"degree","verified":"2026-07-21","type":"guide","steps":["进入 Sydney Student → My Studies","完成 enrolment 步骤和声明","按 handbook 与课程规则选择 units","在 My Studies → Units of study 查看结果"],"sourceKeys":["select_units"],"officialPath":"","prerequisites":[],"sections":[],"warnings":[],"trouble