ings":[],"troubleshooting":[]},{"id":"faq-42","category":"visa","title":"假期能无限工作吗？","summary":"课程不在 session 时通常不受 48 小时限制，但必须核对个人签证和教学日历。","priority":"high","tags":["FAQ","假期"],"source":"visa_dha","stage":"all","verified":"2026-07-21","type":"faq","steps":["先查个人文件与登录后系统","再查官方公开页面","仍不明确时提交官方 enquiry","保存 case number 与书面回复"],"sourceKeys":["visa_dha"],"officialPath":"","prerequisites":[],"sections":[],"warnings":[],"troubleshooting":[]},{"id":"faq-43","category":"study","title":"引用了就一定不算抄袭吗？","summary":"不一定；仍需正确改写、清楚区分原文和自己观点，并按格式引用。","priority":"high","tags":["FAQ","引用"],"source":"integrity","stage":"all","verified":"2026-07-21","type":"faq","steps":["先查个人文件与登录后系统","再查官方公开页面","仍不明确时提交官方 enquiry","保存 case number 与书面回复"],"sourceKeys":["integrity"],"officialPath":"","prerequisites":[],"sections":[],"warnings":[],"troubleshooting":[]},{"id":"faq-44","category":"assessment","title":"Simple Extension 所有作业都能用吗？","summary":"不能；只适用于 eligible written assessments，需查任务和官方条件。","priority":"high","tags":["FAQ","eligible"],"source":"extension","stage":"all","verified":"2026-07-21","type":"faq","steps":["先查个人文件与登录后系统","再查官方公开页面","仍不明确时提交官方 enquiry","保存 case number 与书面回复"],"sourceKeys":["extension"],"officialPath":"","prerequisites":[],"sections":[],"warnings":[],"troubleshooting":[]},{"id":"faq-45","category":"health","title":"OSHC 包含牙科吗？","summary":"基础 OSHC 通常不自动覆盖所有牙科，需查看个人保单或额外保险。","priority":"medium","tags":["FAQ","牙科"],"source":"oshc","stage":"all","verified":"2026-07-21","type":"faq","steps":["先查个人文件与登录后系统","再查官方公开页面","仍不明确时提交官方 enquiry","保存 case number 与书面回复"],"sourceKeys":["oshc"],"officialPath":"","prerequisites":[],"sections":[],"warnings":[],"troubleshooting":[]},{"id":"faq-46","category":"housing","title":"租房没有照片证据怎么办？","summary":"立即补拍当前状况并书面发送，但入住时完成 condition report 最稳妥。","priority":"medium","tags":["FAQ","照片"],"source":"fairtrading","stage":"all","verified":"2026-07-21","type":"faq","steps":["先查个人文件与登录后系统","再查官方公开页面","仍不明确时提交官方 enquiry","保存 case number 与书面回复"],"source