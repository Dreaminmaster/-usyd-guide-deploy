2026-07-21","type":"checklist","steps":["确认个人文件","保存截图或收据","完成后重新登录核验状态","把截止日期加入日历并设置提醒"],"sourceKeys":["card"],"officialPath":"","prerequisites":[],"sections":[],"warnings":[],"troubleshooting":[]},{"id":"check-86","category":"library","title":"归还图书馆物品","summary":"包括书籍和借用设备。","priority":"medium","tags":["清单","毕业"],"source":"library","stage":"all","verified":"2026-07-21","type":"checklist","steps":["确认个人文件","保存截图或收据","完成后重新登录核验状态","把截止日期加入日历并设置提醒"],"sourceKeys":["library"],"officialPath":"","prerequisites":[],"sections":[],"warnings":[],"troubleshooting":[]},{"id":"check-87","category":"work","title":"索取推荐人许可","summary":"不要未经同意填写。","priority":"medium","tags":["清单","毕业"],"source":"careers","stage":"all","verified":"2026-07-21","type":"checklist","steps":["确认个人文件","保存截图或收据","完成后重新登录核验状态","把截止日期加入日历并设置提醒"],"sourceKeys":["careers"],"officialPath":"","prerequisites":[],"sections":[],"warnings":[],"troubleshooting":[]},{"id":"check-88","category":"work","title":"保存合法作品集副本","summary":"移除受限和团队机密。","priority":"medium","tags":["清单","毕业"],"source":"careers","stage":"all","verified":"2026-07-21","type":"checklist","steps":["确认个人文件","保存截图或收据","完成后重新登录核验状态","把截止日期加入日历并设置提醒"],"sourceKeys":["careers"],"officialPath":"","prerequisites":[],"sections":[],"warnings":[],"troubleshooting":[]},{"id":"check-89","category":"systems","title":"更换所有依赖学校邮箱的账号","summary":"使用个人长期邮箱。","priority":"medium","tags":["清单","毕业"],"source":"email","stage":"all","verified":"2026-07-21","type":"checklist","steps":["确认个人文件","保存截图或收据","完成后重新登录核验状态","把截止日期加入日历并设置提醒"],"sourceKeys":["email"],"officialPath":"","prerequisites":[],"sections":[],"warnings":[],"troubleshooting":[]},{"id":"check-90","category":"systems","title":"迁移 Okta 和重要 MFA","summary":"避免旧号或旧邮箱失效。","priority":"medium","tags":["清单","毕业"],"source":"mfa","stage":"all","verified":"2026-07-21","type":"checklist","steps":["确认个人文件","保存截图或收据","完成后重新登录核验状态","把截止日期加入日历并设置提醒"],"sourceKeys":["mfa"],"officialPath":"","prerequisites":[],"sections":[],"warnings":[],"troubleshooting":[]},{"id":"check-91","category":"money","title":"关闭不需要的澳洲订阅","summary":"检查自动续费。","priority":"medium","tags":["清单","毕业"],"source":"moneysmart","stage":"all","verified":"2026-07-21","type":"checklist","steps":["确认个人文件","保存截图或收据","完成后重新登录核验状态","把截止日期加入日历并设置提醒"],"sourceKeys":["moneysmart"],"officialPath":"","prerequisites":[],"sections":[],"warnings":[],"troubleshooting":[]},{"id":"check-92","category":"timeline","title":"保存学校最终书面确认","summary":"毕业、课程完成和离校状态。","priority":"medium","tags":["清单","毕业"],"source":"student_centre","stage":"all","verified":"2026-07-21","type":"checklist","steps":["确认个人文件","保存截图或收据","完成后重新登录核验状态","把截止日期加入日历并设置提醒"],"sourceKeys":["student_centre"],"officialPath":"","prerequisites":[],"sections":[],"warnings":[],"troubleshooting":[]},{"id":"systems-digital-setup","category":"systems","title":"UniKey、Okta、邮箱、MyUni 与 Canvas 首次设置","summary":"按官方数字设置顺序完成账号、安全验证、邮箱、学习系统和校园 Wi‑Fi，避免多个系统同时报错。","priority":"high","tags":["首次设置","UniKey","Okta","Canvas"],"source":"digital_setup","stage":"before","verified":"2026-07-21","type":"guide","steps":["先确认 UniKey 和密码可用","完成 Okta 双重验证并准备备用方式","逐一登录邮箱、Canvas、MyUni、Sydney Student","失败时记录报错截图并联系 ICT Helpdesk"],"sourceKeys":["digital_setup","mfa","email","canvas","wifi"],"officialPath":"UniKey → Okta MFA → Microsoft 365 邮箱 → MyUni / Canvas → UniSydney / eduroam","prerequisites":["已收到 UniKey 或学校账号激活通知。","准备可接收验证的手机与一个备用方式。","使用最新版受支持浏览器，并确保设备日期和时间自动同步。"],"sections":[{"title":"先保护账号","items":["使用学校提供的入口设置或重设 UniKey 密码。","设置 Okta Verify，并在旧设备仍可用时添加备用验证方式。","不要把 UniKey、验证码或屏幕控制权交给他人。"]},{"title":"逐一测试系统","items":["登录 Microsoft 365 / Outlook，测试能否收发学校邮件。","登录 MyUni，确认常用入口可打开。","登录 Canvas，检查 Dashboard、Courses 和通知设置。","登录 Sydney Student，确认个人资料与 My Studies 是否显示。"]},{"title":"到校后连接网络","items":["按学校指引连接 UniSydney 或 eduroam。","只在官方网络配置页面输入 UniKey。","连接后重新测试 Canvas、邮箱和图书馆资源。"]}],"warnings":["不要一次在多个设备上反复输入错误密码，以免触发锁定。","换手机前先处理 Okta；不要清空旧设备后才发现没有备用验证。","MyUni、Canvas 和 Sydney Student 职责不同，某一个正常不代表 enrolment 已完成。"],"troubleshooting":["UniKey 不工作：停止反复尝试，使用官方密码恢复或联系 ICT Helpdesk。","Okta 无法验证：尝试备用方式；没有备用方式时准备身份证明联系 ICT。","Canvas 无课程：核对 enrolment 和课程开放时间，不要因 Canvas 空白重复选课。","校园 Wi‑Fi 失败：删除旧配置，按官方说明重新连接，确认使用正确网络凭据。"]},{"id":"timeline-arrival-update","category":"timeline","title":"国际学生抵达后必须更新的资料","summary":"抵澳后在 Sydney Student 更新 onshore 状态、USI、澳洲住址、手机号和紧急联系人，并再次检查签证与 OSHC。","priority":"high","tags":["抵澳","USI","地址","onshore"],"source":"international_arrival","stage":"arrival","verified":"2026-07-21","type":"guide","steps":["更新澳洲地址与联系方式","完成 onshore / USI 等要求","确认课表、Canvas 和教室","准备实体与数字学生证"],"sourceKeys":["international_arrival","visa_usyd","enrol"],"officialPath":"Sydney Student → My details / Personal details → 地址、联系方式、USI 与抵澳相关项目","prerequisites":["已实际抵达澳大利亚。","可以登录 Sydney Student。","准备澳洲居住地址、澳洲手机号、USI 和紧急联系人信息。"],"sections":[{"title":"抵达后立即检查","items":["查看学校邮件和 Sydney Student 是否要求确认 onshore 状态。","提供或验证 USI，确保姓名与护照/USI 记录一致。","填写澳洲居住地址，不要继续只留海外地址。","添加澳洲手机号和可联系的紧急联系人。"]},{"title":"七天内完成","items":["学生签证持有人应在抵澳或联系方式变化后的 7 天内向教育机构更新住址。","保存更新页面截图或确认信息。","搬家后再次更新，不要等到学校邮件退信。"]},{"title":"同时复核","items":["用 VEVO 检查当前签证条件。","确认 OSHC 保单和会员信息可用。","检查 CoE、课程日期与个人 offer 是否一致。","完成学生证、课表和 Canvas 检查。"]}],"warnings":["不要在尚未抵澳时虚假填写 onshore 状态。","姓名、生日或护照信息不一致时，不要自行猜测修改，先联系学校。","地址变化后也需要更新，不只是第一次抵澳。"],"troubleshooting":["找不到 USI 字段：检查 enrolment 步骤是否完成，并查看学校关于 USI 的提示。","系统不接受地址：使用澳洲邮政格式，核对 suburb、state 和 postcode。","状态已更新但 App 未变：重新登录并允许同步，以 Sydney Student 记录为准。"]},{"id":"enrol-timetable-flow","category":"enrol","title":"从 enrolment 到拿到课表的完整流程","summary":"正式 enrolment、选择 units、Tracking totals、提交 timetable preferences、处理 clash，再确认 Canvas 与教室。","priority":"high","tags":["课表","完整流程","选课"],"source":"enrol","stage":"degree","verified":"2026-07-21","type":"guide","steps":["进入 Sydney Student → My Studies","完成 enrolment 步骤和声明","按 handbook 与课程规则选择 units","在 My Studies → Units of study 查看结果"],"sourceKeys":["enrol","select_units","timetable","canvas"],"officialPath":"Sydney Student enrolment → Units of study → Sydney Timetable → Canvas","prerequisites":["正式学位 enrolment 已开放。","已阅读正确年份 Handbook 和 course resolutions。","准备拟选 unit code 和课程结构。"],"sections":[{"title":"完成 enrolment","items":["在 Sydney Student 的 My Studies 完成 enrolment。","确认个人信息、USI、签证、声明和课程状态。","保存 enrolment confirmation。"]},{"title":"选择并验证 units","items":["按 core、专业、选修和总学分添加 units。","处理 prerequisite 和 teaching period。","检查 Tracking totals，确保所有 collection 正确。","提交并重新打开页面确认保存成功。"]},{"title":"完成课表","items":["进入 Sydney Timetable 查看活动。","在开放期提交 class preferences。","公布后检查 allocation 和 clash。","必要时使用 timetable 流程调整，而不是直接退课。"]},{"title":"最后交叉检查","items":["Canvas 出现的课程应与已选 units 一致。","检查每门课第一周地点、online component 和 compulsory activity。","把 census date、考试期和 assessment 截止日加入日历。"]}],"warnings":["课表问题和课程结构问题不是一回事；不要为解决时间冲突随意删除核心课。","Canvas 暂时没有课程不等于选课失败。","国际学生改变 study load 前先获得书面建议。"],"troubleshooting":["课表没有活动：确认 unit 已保存及 timetable 是否开放。","所有班满：使用 timetable 官方渠道，不要放弃出勤或私下换班。","Canvas 多课或少课：对照 Sydney Student 记录并联系教学团队。"]}],"checklists":{"入学前":[["接受 offer 前核对课程名称和日期","timeline"],["确认所有 offer conditions","timeline"],["下载并核对 CoE","visa"],["确认签证和 VEVO 条件","visa"],["确认 OSHC 覆盖完整课程和签证期间","health"],["建立学校文件云端和离线备份","timeline"],["确认 UniKey 可以登录","systems"],["设置 Okta 和备用验证方式","systems"],["登录学校邮箱并主动检查","systems"],["核对 CET / DEC 开课日期","cet"],["将悉尼时区加入手机","timeline"],["安装 Outlook、Canvas、Okta","systems"],["准备学生证合规照片","card"],["保留原手机号和 MFA","money"]],"抵达悉尼":[["确认抵澳前几晚住宿","housing"],["准备机场到住宿路线","transport"],["保存 OSHC 会员号和联系方式","health"],["准备英文病史、处方和疫苗记录","health"],["准备可立即使用的支付方式","money"],["设置紧急备用金","money"],["更新 onshore 状态","visa"],["提供或验证 USI","enrol"],["七天内更新澳洲地址","visa"],["更新澳洲手机号和紧急联系人","visa"],["办理澳洲手机号","money"],["开设澳洲银行账户","money"],["准备 Adult Opal 或 contactless","transport"],["完成 condition report","housing"],["确认 bond 正式登记","housing"],["实测住宿到学校通勤","transport"]],"报到与开课":[["连接 UniSydney 或 eduroam","systems"],["提交并确认学生证照片获批","card"],["领取实体学生证","card"],["将数字学生证加入 Wallet","card"],["打开 Canvas 并检查课程","systems"],["检查 enrolment 状态",